# Copy this file to `.env` and fill in real values.
# The real .env is gitignored — never commit secrets.

# --- Anthropic (Claude) ---
# Create at https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# --- Google Cloud (Gemini via Vertex AI) ---
# Your GCP project ID (find with: gcloud projects list).
# Gemini auth uses ADC, not a key: gcloud auth application-default login
GCP_PROJECT=your-project-id
GCP_LOCATION=global

# --- Optional overrides (defaults shown) ---
# CLAUDE_MODEL=claude-opus-4-8
# GEMINI_MODEL=gemini-3.5-flash
# MAX_TOKENS=1024

# --- Fine-tuned model (set AFTER the Vertex tuning job completes) ---
# TUNED_GEMINI_MODEL=projects/<num>/locations/us-central1/models/<id>
# TUNED_GEMINI_LOCATION=us-central1
